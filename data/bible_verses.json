[
  {
    "day_of_year": 1,
    "verse_text": "我躺下睡覺，我醒著，耶和華都保佑我",
    "reference": "詩篇 3:5",
    "theme": "sleep"
  },
  {
    "day_of_year": 2,
    "verse_text": "我必安然躺下睡覺，耶和華使我安然居住",
    "reference": "詩篇 4:8",
    "theme": "sleep"
  },
  {
    "day_of_year": 3,
    "verse_text": "你們應當畏懼，不可犯罪",
    "reference": "詩篇 4:4",
    "theme": "calm"
  },
  {
    "day_of_year": 4,
    "verse_text": "我的心歡喜，我的靈快樂，肉身安然居住",
    "reference": "詩篇 16:9",
    "theme": "peace"
  },
  {
    "day_of_year": 5,
    "verse_text": "耶和華是我的牧者，我必不致缺乏",
    "reference": "詩篇 23:1",
    "theme": "peace"
  },
  {
    "day_of_year": 6,
    "verse_text": "他使我躺臥在青草地上，領我在可安歇的水邊",
    "reference": "詩篇 23:2",
    "theme": "rest"
  },
  {
    "day_of_year": 7,
    "verse_text": "他使我的靈魂甦醒，為自己的名引導我走義路",
    "reference": "詩篇 23:3",
    "theme": "calm"
  },
  {
    "day_of_year": 8,
    "verse_text": "我雖然行過死蔭的幽谷，也不怕遭害",
    "reference": "詩篇 23:4",
    "theme": "peace"
  },
  {
    "day_of_year": 9,
    "verse_text": "在我敵人面前，你為我擺設筵席",
    "reference": "詩篇 23:5",
    "theme": "calm"
  },
  {
    "day_of_year": 10,
    "verse_text": "我一生一世必有恩惠慈愛隨著我",
    "reference": "詩篇 23:6",
    "theme": "peace"
  },
  {
    "day_of_year": 11,
    "verse_text": "耶和華是我的亮光，是我的拯救",
    "reference": "詩篇 27:1",
    "theme": "calm"
  },
  {
    "day_of_year": 12,
    "verse_text": "耶和華必賜平安的福給他的百姓",
    "reference": "詩篇 29:11",
    "theme": "peace"
  },
  {
    "day_of_year": 13,
    "verse_text": "你們要嘗嘗主恩的滋味，便知道他是美善",
    "reference": "詩篇 34:8",
    "theme": "calm"
  },
  {
    "day_of_year": 14,
    "verse_text": "要離惡行善，尋求和睦，一心追趕",
    "reference": "詩篇 34:14",
    "theme": "peace"
  },
  {
    "day_of_year": 15,
    "verse_text": "又要以耶和華為樂，他就將你心裡所求的賜給你",
    "reference": "詩篇 37:4",
    "theme": "peace"
  },
  {
    "day_of_year": 16,
    "verse_text": "你當默然倚靠耶和華，耐性等候他",
    "reference": "詩篇 37:7",
    "theme": "rest"
  },
  {
    "day_of_year": 17,
    "verse_text": "神是我們的避難所，是我們的力量",
    "reference": "詩篇 46:1",
    "theme": "calm"
  },
  {
    "day_of_year": 18,
    "verse_text": "你們要休息，要知道我是神",
    "reference": "詩篇 46:10",
    "theme": "rest"
  },
  {
    "day_of_year": 19,
    "verse_text": "你要把你的重擔卸給耶和華，他必撫養你",
    "reference": "詩篇 55:22",
    "theme": "rest"
  },
  {
    "day_of_year": 20,
    "verse_text": "我的心默默無聲，專等候神",
    "reference": "詩篇 62:1",
    "theme": "rest"
  },
  {
    "day_of_year": 21,
    "verse_text": "我的心哪，你當默然無聲，專等候神",
    "reference": "詩篇 62:5",
    "theme": "calm"
  },
  {
    "day_of_year": 22,
    "verse_text": "我在床上記念你，在夜更的時候思想你",
    "reference": "詩篇 63:5",
    "theme": "sleep"
  },
  {
    "day_of_year": 23,
    "verse_text": "我在床上記念你，我的心就像飽足了骨髓肥油",
    "reference": "詩篇 63:6",
    "theme": "peace"
  },
  {
    "day_of_year": 24,
    "verse_text": "住在至高者隱密處的，必住在全能者的蔭下",
    "reference": "詩篇 91:1",
    "theme": "calm"
  },
  {
    "day_of_year": 25,
    "verse_text": "我要論到耶和華說，他是我的避難所",
    "reference": "詩篇 91:2",
    "theme": "peace"
  },
  {
    "day_of_year": 26,
    "verse_text": "我的心哪，你要仍歸安樂，因為耶和華用厚恩待你",
    "reference": "詩篇 116:7",
    "theme": "peace"
  },
  {
    "day_of_year": 27,
    "verse_text": "保護以色列的也不打盹也不睡覺",
    "reference": "詩篇 121:3",
    "theme": "sleep"
  },
  {
    "day_of_year": 28,
    "verse_text": "保護以色列的，也不打盹也不睡覺",
    "reference": "詩篇 121:4",
    "theme": "calm"
  },
  {
    "day_of_year": 29,
    "verse_text": "惟有耶和華所親愛的，必叫他安然睡覺",
    "reference": "詩篇 127:2",
    "theme": "sleep"
  },
  {
    "day_of_year": 30,
    "verse_text": "我心裡多憂多疑，你安慰我，就使我歡樂",
    "reference": "詩篇 94:19",
    "theme": "peace"
  },
  {
    "day_of_year": 31,
    "verse_text": "愛你律法的人有大平安，什麼都不能使他們絆腳",
    "reference": "詩篇 119:165",
    "theme": "peace"
  },
  {
    "day_of_year": 32,
    "verse_text": "我雖行在患難中，你必將我救活",
    "reference": "詩篇 138:7",
    "theme": "calm"
  },
  {
    "day_of_year": 33,
    "verse_text": "我睡醒的時候，仍和你同在",
    "reference": "詩篇 139:18",
    "theme": "sleep"
  },
  {
    "day_of_year": 34,
    "verse_text": "你躺下必不懼怕，你躺臥睡得香甜",
    "reference": "箴言 3:24",
    "theme": "sleep"
  },
  {
    "day_of_year": 35,
    "verse_text": "心中安靜是肉體的生命",
    "reference": "箴言 14:30",
    "theme": "calm"
  },
  {
    "day_of_year": 36,
    "verse_text": "人所行的若蒙耶和華喜悅，耶和華也使他的仇敵與他和好",
    "reference": "箴言 16:7",
    "theme": "peace"
  },
  {
    "day_of_year": 37,
    "verse_text": "喜樂的心乃是良藥，憂傷的靈使骨枯乾",
    "reference": "箴言 17:22",
    "theme": "calm"
  },
  {
    "day_of_year": 38,
    "verse_text": "敬畏耶和華的，得著生命，他必恆久知足",
    "reference": "箴言 19:23",
    "theme": "peace"
  },
  {
    "day_of_year": 39,
    "verse_text": "堅心倚賴你的，你必保守他十分平安",
    "reference": "以賽亞書 26:3",
    "theme": "peace"
  },
  {
    "day_of_year": 40,
    "verse_text": "你們得救在乎歸回安息，你們得力在乎平靜安穩",
    "reference": "以賽亞書 30:15",
    "theme": "rest"
  },
  {
    "day_of_year": 41,
    "verse_text": "公義的果效必是平安，公義的效驗必是平穩",
    "reference": "以賽亞書 32:17",
    "theme": "peace"
  },
  {
    "day_of_year": 42,
    "verse_text": "你不要害怕，因為我與你同在",
    "reference": "以賽亞書 41:10",
    "theme": "calm"
  },
  {
    "day_of_year": 43,
    "verse_text": "因他受的鞭傷，我們得醫治",
    "reference": "以賽亞書 53:5",
    "theme": "peace"
  },
  {
    "day_of_year": 44,
    "verse_text": "我必親自和你同去，使你得安息",
    "reference": "出埃及記 33:14",
    "theme": "rest"
  },
  {
    "day_of_year": 45,
    "verse_text": "耶和華說，我知道我向你們所懷的意念，是賜平安的意念",
    "reference": "耶利米書 29:11",
    "theme": "peace"
  },
  {
    "day_of_year": 46,
    "verse_text": "疲乏的人我使他飽飫，愁煩的人我使他知足",
    "reference": "耶利米書 31:25",
    "theme": "rest"
  },
  {
    "day_of_year": 47,
    "verse_text": "滿了一把得享安靜，強如滿了兩把勞碌捕風",
    "reference": "傳道書 4:6",
    "theme": "rest"
  },
  {
    "day_of_year": 48,
    "verse_text": "事情的終局強如事情的起頭，存心忍耐的勝過居心驕傲的",
    "reference": "傳道書 7:8",
    "theme": "calm"
  },
  {
    "day_of_year": 49,
    "verse_text": "你因有指望就必穩固，也必四圍巡查，坦然安息",
    "reference": "約伯記 11:18",
    "theme": "rest"
  },
  {
    "day_of_year": 50,
    "verse_text": "你要認識神，就得平安，福氣也必臨到你",
    "reference": "約伯記 22:21",
    "theme": "peace"
  },
  {
    "day_of_year": 51,
    "verse_text": "不要為明天憂慮，明天自有明天的憂慮",
    "reference": "馬太福音 6:34",
    "theme": "calm"
  },
  {
    "day_of_year": 52,
    "verse_text": "凡勞苦擔重擔的人，可以到我這裡來，我就使你們得安息",
    "reference": "馬太福音 11:28",
    "theme": "rest"
  },
  {
    "day_of_year": 53,
    "verse_text": "我心裡柔和謙卑，你們當負我的軛，學我的樣式",
    "reference": "馬太福音 11:29",
    "theme": "rest"
  },
  {
    "day_of_year": 54,
    "verse_text": "住了吧，靜了吧，風就止住，大大地平靜了",
    "reference": "馬可福音 4:39",
    "theme": "calm"
  },
  {
    "day_of_year": 55,
    "verse_text": "馬大，馬大，你為許多的事思慮煩擾",
    "reference": "路加福音 10:41",
    "theme": "calm"
  },
  {
    "day_of_year": 56,
    "verse_text": "我留下平安給你們，我將我的平安賜給你們",
    "reference": "約翰福音 14:27",
    "theme": "peace"
  },
  {
    "day_of_year": 57,
    "verse_text": "在世上你們有苦難，但你們可以放心，我已經勝了世界",
    "reference": "約翰福音 16:33",
    "theme": "peace"
  },
  {
    "day_of_year": 58,
    "verse_text": "我們既因信稱義，就藉著我們的主耶穌基督得與神相和",
    "reference": "羅馬書 5:1",
    "theme": "peace"
  },
  {
    "day_of_year": 59,
    "verse_text": "體貼聖靈的乃是生命平安",
    "reference": "羅馬書 8:6",
    "theme": "peace"
  },
  {
    "day_of_year": 60,
    "verse_text": "但願使人有盼望的神，因信將諸般的喜樂平安充滿你們",
    "reference": "羅馬書 15:13",
    "theme": "peace"
  },
  {
    "day_of_year": 61,
    "verse_text": "願頌讚歸與我們的主耶穌基督的父神，就是發慈悲的父",
    "reference": "歌林多後書 1:3",
    "theme": "calm"
  },
  {
    "day_of_year": 62,
    "verse_text": "因他使我們和睦，將兩下合而為一",
    "reference": "以弗所書 2:14",
    "theme": "peace"
  },
  {
    "day_of_year": 63,
    "verse_text": "應當一無掛慮，只要凡事藉著禱告祈求，將所要的告訴神",
    "reference": "腓立比書 4:6",
    "theme": "calm"
  },
  {
    "day_of_year": 64,
    "verse_text": "神所賜出人意外的平安，必在基督耶穌裡保守你們的心",
    "reference": "腓立比書 4:7",
    "theme": "peace"
  },
  {
    "day_of_year": 65,
    "verse_text": "又要叫基督的平安在你們心裡作主",
    "reference": "歌羅西書 3:15",
    "theme": "peace"
  },
  {
    "day_of_year": 66,
    "verse_text": "願賜平安的主，隨時隨事親自給你們平安",
    "reference": "帖撒羅尼迦後書 3:16",
    "theme": "peace"
  },
  {
    "day_of_year": 67,
    "verse_text": "你們要將一切的憂慮卸給神，因為他顧念你們",
    "reference": "彼得前書 5:7",
    "theme": "rest"
  },
  {
    "day_of_year": 68,
    "verse_text": "這樣，必另有一安息日的安息，為神的子民存留",
    "reference": "希伯來書 4:9",
    "theme": "rest"
  },
  {
    "day_of_year": 69,
    "verse_text": "我總不撇下你，也不丟棄你",
    "reference": "希伯來書 13:5",
    "theme": "calm"
  },
  {
    "day_of_year": 70,
    "verse_text": "耶和華你的神是施行拯救，大有能力的主，他在你中間",
    "reference": "西番雅書 3:17",
    "theme": "peace"
  },
  {
    "day_of_year": 71,
    "verse_text": "凡投靠你的，願他們喜樂，時常歡呼",
    "reference": "詩篇 5:11",
    "theme": "peace"
  },
  {
    "day_of_year": 72,
    "verse_text": "耶和華又要給受欺壓的人作高臺，在患難的時候作高臺",
    "reference": "詩篇 9:9",
    "theme": "calm"
  },
  {
    "day_of_year": 73,
    "verse_text": "耶和華是我的巖石，我的山寨，我的救主",
    "reference": "詩篇 18:2",
    "theme": "calm"
  },
  {
    "day_of_year": 74,
    "verse_text": "要等候耶和華，當壯膽，堅固你的心",
    "reference": "詩篇 27:14",
    "theme": "rest"
  },
  {
    "day_of_year": 75,
    "verse_text": "凡仰望耶和華的人，你們都要壯膽，堅固你們的心",
    "reference": "詩篇 31:24",
    "theme": "calm"
  },
  {
    "day_of_year": 76,
    "verse_text": "你是我藏身之處，你必保佑我脫離苦難",
    "reference": "詩篇 32:7",
    "theme": "peace"
  },
  {
    "day_of_year": 77,
    "verse_text": "我們的心向來等候耶和華，他是我們的幫助",
    "reference": "詩篇 33:20",
    "theme": "rest"
  },
  {
    "day_of_year": 78,
    "verse_text": "我曾尋求耶和華，他就應允我，救我脫離了一切的恐懼",
    "reference": "詩篇 34:4",
    "theme": "calm"
  },
  {
    "day_of_year": 79,
    "verse_text": "耶和華靠近傷心的人，拯救靈性痛悔的人",
    "reference": "詩篇 34:18",
    "theme": "peace"
  },
  {
    "day_of_year": 80,
    "verse_text": "當將你的事交託耶和華，並倚靠他，他就必成全",
    "reference": "詩篇 37:5",
    "theme": "rest"
  },
  {
    "day_of_year": 81,
    "verse_text": "謙卑人必承受地土，以豐盛的平安為樂",
    "reference": "詩篇 37:11",
    "theme": "peace"
  },
  {
    "day_of_year": 82,
    "verse_text": "義人的腳步被耶和華立定，他的道路耶和華也喜愛",
    "reference": "詩篇 37:23",
    "theme": "calm"
  },
  {
    "day_of_year": 83,
    "verse_text": "我曾耐性等候耶和華，他垂聽我的呼求",
    "reference": "詩篇 40:1",
    "theme": "rest"
  },
  {
    "day_of_year": 84,
    "verse_text": "我的心哪，你為何憂悶，為何在我裡面煩躁",
    "reference": "詩篇 42:5",
    "theme": "calm"
  },
  {
    "day_of_year": 85,
    "verse_text": "所以地雖改變，山雖搖動到海心，我們也不害怕",
    "reference": "詩篇 46:2",
    "theme": "peace"
  },
  {
    "day_of_year": 86,
    "verse_text": "神啊，求你為我造清潔的心，使我裡面重新有正直的靈",
    "reference": "詩篇 51:10",
    "theme": "calm"
  },
  {
    "day_of_year": 87,
    "verse_text": "我懼怕的時候要倚靠你",
    "reference": "詩篇 56:3",
    "theme": "calm"
  },
  {
    "day_of_year": 88,
    "verse_text": "我要歌頌你的力量，早晨要高唱你的慈愛",
    "reference": "詩篇 59:16",
    "theme": "peace"
  },
  {
    "day_of_year": 89,
    "verse_text": "我心裡發昏的時候，我要從地極求告你",
    "reference": "詩篇 61:2",
    "theme": "rest"
  },
  {
    "day_of_year": 90,
    "verse_text": "你們眾民當時時倚靠他，在他面前傾心吐意",
    "reference": "詩篇 62:8",
    "theme": "rest"
  },
  {
    "day_of_year": 91,
    "verse_text": "天天背負我們重擔的主，就是拯救我們的神",
    "reference": "詩篇 68:19",
    "theme": "rest"
  },
  {
    "day_of_year": 92,
    "verse_text": "我卻要常常盼望，並要越發讚美你",
    "reference": "詩篇 71:14",
    "theme": "peace"
  },
  {
    "day_of_year": 93,
    "verse_text": "我的肉體和我的心腸衰殘，但神是我心裡的力量",
    "reference": "詩篇 73:26",
    "theme": "calm"
  },
  {
    "day_of_year": 94,
    "verse_text": "我要聽神耶和華所說的話，因為他必應許將平安賜給他",
    "reference": "詩篇 85:8",
    "theme": "peace"
  },
  {
    "day_of_year": 95,
    "verse_text": "主啊，你本為良善，樂意饒恕人",
    "reference": "詩篇 86:5",
    "theme": "calm"
  },
  {
    "day_of_year": 96,
    "verse_text": "求你使我們早早飽得你的慈愛，好叫我們一生一世歡呼",
    "reference": "詩篇 90:14",
    "theme": "peace"
  },
  {
    "day_of_year": 97,
    "verse_text": "他必用自己的翎毛遮蔽你，你要投靠在他的翅膀底下",
    "reference": "詩篇 91:4",
    "theme": "calm"
  },
  {
    "day_of_year": 98,
    "verse_text": "因他要為你吩咐他的使者，在你行的一切道路上保護你",
    "reference": "詩篇 91:11",
    "theme": "peace"
  },
  {
    "day_of_year": 99,
    "verse_text": "我正說我失了腳，耶和華啊，那時你的慈愛扶助我",
    "reference": "詩篇 94:18",
    "theme": "calm"
  },
  {
    "day_of_year": 100,
    "verse_text": "我的心哪，你要稱頌耶和華，不可忘記他的一切恩惠",
    "reference": "詩篇 103:2",
    "theme": "peace"
  },
  {
    "day_of_year": 101,
    "verse_text": "東離西有多遠，他叫我們的過犯離我們也有多遠",
    "reference": "詩篇 103:12",
    "theme": "peace"
  },
  {
    "day_of_year": 102,
    "verse_text": "他使狂風止息，波浪就平靜",
    "reference": "詩篇 107:29",
    "theme": "calm"
  },
  {
    "day_of_year": 103,
    "verse_text": "主啊，你救我的命免了死亡，救我的眼免了流淚",
    "reference": "詩篇 116:8",
    "theme": "peace"
  },
  {
    "day_of_year": 104,
    "verse_text": "有耶和華幫助我，我必不懼怕",
    "reference": "詩篇 118:6",
    "theme": "calm"
  },
  {
    "day_of_year": 105,
    "verse_text": "求你照著應許僕人的話，以慈愛安慰我",
    "reference": "詩篇 119:76",
    "theme": "peace"
  },
  {
    "day_of_year": 106,
    "verse_text": "保護你的是耶和華，耶和華在你右邊蔭庇你",
    "reference": "詩篇 121:5",
    "theme": "calm"
  },
  {
    "day_of_year": 107,
    "verse_text": "耶和華要保護你，免受一切的災害",
    "reference": "詩篇 121:7",
    "theme": "peace"
  },
  {
    "day_of_year": 108,
    "verse_text": "倚靠耶和華的人，好像錫安山，永不動搖",
    "reference": "詩篇 125:1",
    "theme": "rest"
  },
  {
    "day_of_year": 109,
    "verse_text": "我的心平穩安靜，好像斷過奶的孩子在他母親的懷中",
    "reference": "詩篇 131:2",
    "theme": "calm"
  },
  {
    "day_of_year": 110,
    "verse_text": "我呼求的日子，你就應允我，鼓勵我，使我心裡有能力",
    "reference": "詩篇 138:3",
    "theme": "peace"
  },
  {
    "day_of_year": 111,
    "verse_text": "神啊，求你鑒察我，知道我的心思",
    "reference": "詩篇 139:23",
    "theme": "calm"
  },
  {
    "day_of_year": 112,
    "verse_text": "耶和華啊，我曾向你哀求，我說，你是我的避難所",
    "reference": "詩篇 142:5",
    "theme": "rest"
  },
  {
    "day_of_year": 113,
    "verse_text": "求你使我清晨得聽你慈愛之言，因我倚靠你",
    "reference": "詩篇 143:8",
    "theme": "peace"
  },
  {
    "day_of_year": 114,
    "verse_text": "凡求告耶和華的，就是誠心求告他的，耶和華便與他們",
    "reference": "詩篇 145:18",
    "theme": "calm"
  },
  {
    "day_of_year": 115,
    "verse_text": "他醫好傷心的人，裹好他們的傷處",
    "reference": "詩篇 147:3",
    "theme": "peace"
  },
  {
    "day_of_year": 116,
    "verse_text": "惟有聽從我的，必安然居住，得享安靜",
    "reference": "箴言 1:33",
    "theme": "rest"
  },
  {
    "day_of_year": 117,
    "verse_text": "你要專心仰賴耶和華，不可倚靠自己的聰明",
    "reference": "箴言 3:5",
    "theme": "calm"
  },
  {
    "day_of_year": 118,
    "verse_text": "在你一切所行的事上都要認定他，他必指引你的路",
    "reference": "箴言 3:6",
    "theme": "calm"
  },
  {
    "day_of_year": 119,
    "verse_text": "耶和華所賜的福，使人富足，並不加上憂慮",
    "reference": "箴言 10:22",
    "theme": "peace"
  },
  {
    "day_of_year": 120,
    "verse_text": "人心憂慮屈而不伸，一句良言使心歡樂",
    "reference": "箴言 12:25",
    "theme": "calm"
  },
  {
    "day_of_year": 121,
    "verse_text": "敬畏耶和華的，大有倚靠，他的兒女也有避難所",
    "reference": "箴言 14:26",
    "theme": "calm"
  },
  {
    "day_of_year": 122,
    "verse_text": "你所作的，要交託耶和華，你所謀的，就必成立",
    "reference": "箴言 16:3",
    "theme": "rest"
  },
  {
    "day_of_year": 123,
    "verse_text": "耶和華的名是堅固臺，義人奔入便得安穩",
    "reference": "箴言 18:10",
    "theme": "calm"
  },
  {
    "day_of_year": 124,
    "verse_text": "敬畏耶和華的，得著生命，他必恆久知足",
    "reference": "箴言 19:23",
    "theme": "peace"
  },
  {
    "day_of_year": 125,
    "verse_text": "心中自是的，便是愚昧人，憑智慧行事的，必蒙拯救",
    "reference": "箴言 28:26",
    "theme": "calm"
  },
  {
    "day_of_year": 126,
    "verse_text": "他名稱為奇妙策士，全能的神，永在的父，和平的君",
    "reference": "以賽亞書 9:6",
    "theme": "peace"
  },
  {
    "day_of_year": 127,
    "verse_text": "看哪，神是我的拯救，我要倚靠他，並不懼怕",
    "reference": "以賽亞書 12:2",
    "theme": "calm"
  },
  {
    "day_of_year": 128,
    "verse_text": "因為當強暴人催逼人的時候，如同暴風直吹牆壁",
    "reference": "以賽亞書 25:4",
    "theme": "calm"
  },
  {
    "day_of_year": 129,
    "verse_text": "耶和華啊，求你施恩於我們，我們等候你",
    "reference": "以賽亞書 33:2",
    "theme": "rest"
  },
  {
    "day_of_year": 130,
    "verse_text": "但那等候耶和華的，必從新得力",
    "reference": "以賽亞書 40:31",
    "theme": "rest"
  },
  {
    "day_of_year": 131,
    "verse_text": "你從水中經過，我必與你同在",
    "reference": "以賽亞書 43:2",
    "theme": "calm"
  },
  {
    "day_of_year": 132,
    "verse_text": "我對你的慈愛永不離開，我平安的約也不遷移",
    "reference": "以賽亞書 54:10",
    "theme": "peace"
  },
  {
    "day_of_year": 133,
    "verse_text": "你們必歡歡喜喜而出來，平平安安蒙引導",
    "reference": "以賽亞書 55:12",
    "theme": "peace"
  },
  {
    "day_of_year": 134,
    "verse_text": "倚靠耶和華，以耶和華為可靠的，那人有福了",
    "reference": "耶利米書 17:7",
    "theme": "peace"
  },
  {
    "day_of_year": 135,
    "verse_text": "看哪，我要使這城得以痊愈安舒",
    "reference": "耶利米書 33:6",
    "theme": "peace"
  },
  {
    "day_of_year": 136,
    "verse_text": "凡事都有定期，天下萬務都有定時",
    "reference": "傳道書 3:1",
    "theme": "calm"
  },
  {
    "day_of_year": 137,
    "verse_text": "你不要心裡急躁惱怒，因為惱怒存在愚昧人的懷中",
    "reference": "傳道書 7:9",
    "theme": "calm"
  },
  {
    "day_of_year": 138,
    "verse_text": "你六次遭難，他必救你，就是七次，災禍也無法害你",
    "reference": "約伯記 5:19",
    "theme": "peace"
  },
  {
    "day_of_year": 139,
    "verse_text": "你就要以全能者為喜樂，向神仰起臉來",
    "reference": "約伯記 22:26",
    "theme": "peace"
  },
  {
    "day_of_year": 140,
    "verse_text": "使人和睦的人有福了，因為他們必稱為神的兒子",
    "reference": "馬太福音 5:9",
    "theme": "peace"
  },
  {
    "day_of_year": 141,
    "verse_text": "所以我告訴你們，不要為生命憂慮",
    "reference": "馬太福音 6:25",
    "theme": "calm"
  },
  {
    "day_of_year": 142,
    "verse_text": "你們放心，是我，不要怕",
    "reference": "馬太福音 14:27",
    "theme": "calm"
  },
  {
    "day_of_year": 143,
    "verse_text": "你們來同我暗暗地到曠野地方去歇一歇",
    "reference": "馬可福音 6:31",
    "theme": "rest"
  },
  {
    "day_of_year": 144,
    "verse_text": "在至高之處榮耀歸與神，在地上平安歸與他所喜悅的人",
    "reference": "路加福音 2:14",
    "theme": "peace"
  },
  {
    "day_of_year": 145,
    "verse_text": "不要怕，只要信",
    "reference": "路加福音 8:50",
    "theme": "calm"
  },
  {
    "day_of_year": 146,
    "verse_text": "你們心裡不要憂愁，你們信神，也當信我",
    "reference": "約翰福音 14:1",
    "theme": "calm"
  },
  {
    "day_of_year": 147,
    "verse_text": "我不撇下你們為孤兒，我必到你們這裡來",
    "reference": "約翰福音 14:18",
    "theme": "peace"
  },
  {
    "day_of_year": 148,
    "verse_text": "萬事都互相效力，叫愛神的人得益處",
    "reference": "羅馬書 8:28",
    "theme": "peace"
  },
  {
    "day_of_year": 149,
    "verse_text": "因為我深信無論是死，是生，都不能叫我們與神的愛隔絕",
    "reference": "羅馬書 8:38",
    "theme": "peace"
  },
  {
    "day_of_year": 150,
    "verse_text": "若是能行，總要盡力與眾人和睦",
    "reference": "羅馬書 12:18",
    "theme": "peace"
  },
  {
    "day_of_year": 151,
    "verse_text": "所以我們不喪膽，外體雖然毀壞，內心卻一天新似一天",
    "reference": "歌林多後書 4:16",
    "theme": "calm"
  },
  {
    "day_of_year": 152,
    "verse_text": "又用平安的福音當作預備走路的鞋穿在腳上",
    "reference": "以弗所書 6:15",
    "theme": "peace"
  },
  {
    "day_of_year": 153,
    "verse_text": "弟兄們，我還有未盡的話，凡是真實的，可敬的，公義",
    "reference": "腓立比書 4:8",
    "theme": "calm"
  },
  {
    "day_of_year": 154,
    "verse_text": "你們在我身上所學習的，所領受的，所聽見的，所看見",
    "reference": "腓立比書 4:9",
    "theme": "peace"
  },
  {
    "day_of_year": 155,
    "verse_text": "既然藉著他在十字架上所流的血成就了和平",
    "reference": "歌羅西書 1:20",
    "theme": "peace"
  },
  {
    "day_of_year": 156,
    "verse_text": "也要離惡行善，尋求和睦，一心追趕",
    "reference": "彼得前書 3:11",
    "theme": "peace"
  },
  {
    "day_of_year": 157,
    "verse_text": "所以我們只管坦然無懼地來到施恩的寶座前",
    "reference": "希伯來書 4:16",
    "theme": "calm"
  },
  {
    "day_of_year": 158,
    "verse_text": "你們要追求與眾人和睦",
    "reference": "希伯來書 12:14",
    "theme": "peace"
  },
  {
    "day_of_year": 159,
    "verse_text": "我躺下睡覺，我醒著，耶和華都保佑我",
    "reference": "詩篇 3:5",
    "theme": "sleep"
  },
  {
    "day_of_year": 160,
    "verse_text": "我必安然躺下睡覺，耶和華使我安然居住",
    "reference": "詩篇 4:8",
    "theme": "sleep"
  },
  {
    "day_of_year": 161,
    "verse_text": "你們應當畏懼，不可犯罪",
    "reference": "詩篇 4:4",
    "theme": "calm"
  },
  {
    "day_of_year": 162,
    "verse_text": "我的心歡喜，我的靈快樂，肉身安然居住",
    "reference": "詩篇 16:9",
    "theme": "peace"
  },
  {
    "day_of_year": 163,
    "verse_text": "耶和華是我的牧者，我必不致缺乏",
    "reference": "詩篇 23:1",
    "theme": "peace"
  },
  {
    "day_of_year": 164,
    "verse_text": "他使我躺臥在青草地上，領我在可安歇的水邊",
    "reference": "詩篇 23:2",
    "theme": "rest"
  },
  {
    "day_of_year": 165,
    "verse_text": "他使我的靈魂甦醒，為自己的名引導我走義路",
    "reference": "詩篇 23:3",
    "theme": "calm"
  },
  {
    "day_of_year": 166,
    "verse_text": "我雖然行過死蔭的幽谷，也不怕遭害",
    "reference": "詩篇 23:4",
    "theme": "peace"
  },
  {
    "day_of_year": 167,
    "verse_text": "在我敵人面前，你為我擺設筵席",
    "reference": "詩篇 23:5",
    "theme": "calm"
  },
  {
    "day_of_year": 168,
    "verse_text": "我一生一世必有恩惠慈愛隨著我",
    "reference": "詩篇 23:6",
    "theme": "peace"
  },
  {
    "day_of_year": 169,
    "verse_text": "耶和華是我的亮光，是我的拯救",
    "reference": "詩篇 27:1",
    "theme": "calm"
  },
  {
    "day_of_year": 170,
    "verse_text": "耶和華必賜平安的福給他的百姓",
    "reference": "詩篇 29:11",
    "theme": "peace"
  },
  {
    "day_of_year": 171,
    "verse_text": "你們要嘗嘗主恩的滋味，便知道他是美善",
    "reference": "詩篇 34:8",
    "theme": "calm"
  },
  {
    "day_of_year": 172,
    "verse_text": "要離惡行善，尋求和睦，一心追趕",
    "reference": "詩篇 34:14",
    "theme": "peace"
  },
  {
    "day_of_year": 173,
    "verse_text": "又要以耶和華為樂，他就將你心裡所求的賜給你",
    "reference": "詩篇 37:4",
    "theme": "peace"
  },
  {
    "day_of_year": 174,
    "verse_text": "你當默然倚靠耶和華，耐性等候他",
    "reference": "詩篇 37:7",
    "theme": "rest"
  },
  {
    "day_of_year": 175,
    "verse_text": "神是我們的避難所，是我們的力量",
    "reference": "詩篇 46:1",
    "theme": "calm"
  },
  {
    "day_of_year": 176,
    "verse_text": "你們要休息，要知道我是神",
    "reference": "詩篇 46:10",
    "theme": "rest"
  },
  {
    "day_of_year": 177,
    "verse_text": "你要把你的重擔卸給耶和華，他必撫養你",
    "reference": "詩篇 55:22",
    "theme": "rest"
  },
  {
    "day_of_year": 178,
    "verse_text": "我的心默默無聲，專等候神",
    "reference": "詩篇 62:1",
    "theme": "rest"
  },
  {
    "day_of_year": 179,
    "verse_text": "我的心哪，你當默然無聲，專等候神",
    "reference": "詩篇 62:5",
    "theme": "calm"
  },
  {
    "day_of_year": 180,
    "verse_text": "我在床上記念你，在夜更的時候思想你",
    "reference": "詩篇 63:5",
    "theme": "sleep"
  },
  {
    "day_of_year": 181,
    "verse_text": "我在床上記念你，我的心就像飽足了骨髓肥油",
    "reference": "詩篇 63:6",
    "theme": "peace"
  },
  {
    "day_of_year": 182,
    "verse_text": "住在至高者隱密處的，必住在全能者的蔭下",
    "reference": "詩篇 91:1",
    "theme": "calm"
  },
  {
    "day_of_year": 183,
    "verse_text": "我要論到耶和華說，他是我的避難所",
    "reference": "詩篇 91:2",
    "theme": "peace"
  },
  {
    "day_of_year": 184,
    "verse_text": "我的心哪，你要仍歸安樂，因為耶和華用厚恩待你",
    "reference": "詩篇 116:7",
    "theme": "peace"
  },
  {
    "day_of_year": 185,
    "verse_text": "保護以色列的也不打盹也不睡覺",
    "reference": "詩篇 121:3",
    "theme": "sleep"
  },
  {
    "day_of_year": 186,
    "verse_text": "保護以色列的，也不打盹也不睡覺",
    "reference": "詩篇 121:4",
    "theme": "calm"
  },
  {
    "day_of_year": 187,
    "verse_text": "惟有耶和華所親愛的，必叫他安然睡覺",
    "reference": "詩篇 127:2",
    "theme": "sleep"
  },
  {
    "day_of_year": 188,
    "verse_text": "我心裡多憂多疑，你安慰我，就使我歡樂",
    "reference": "詩篇 94:19",
    "theme": "peace"
  },
  {
    "day_of_year": 189,
    "verse_text": "愛你律法的人有大平安，什麼都不能使他們絆腳",
    "reference": "詩篇 119:165",
    "theme": "peace"
  },
  {
    "day_of_year": 190,
    "verse_text": "我雖行在患難中，你必將我救活",
    "reference": "詩篇 138:7",
    "theme": "calm"
  },
  {
    "day_of_year": 191,
    "verse_text": "我睡醒的時候，仍和你同在",
    "reference": "詩篇 139:18",
    "theme": "sleep"
  },
  {
    "day_of_year": 192,
    "verse_text": "你躺下必不懼怕，你躺臥睡得香甜",
    "reference": "箴言 3:24",
    "theme": "sleep"
  },
  {
    "day_of_year": 193,
    "verse_text": "心中安靜是肉體的生命",
    "reference": "箴言 14:30",
    "theme": "calm"
  },
  {
    "day_of_year": 194,
    "verse_text": "人所行的若蒙耶和華喜悅，耶和華也使他的仇敵與他和好",
    "reference": "箴言 16:7",
    "theme": "peace"
  },
  {
    "day_of_year": 195,
    "verse_text": "喜樂的心乃是良藥，憂傷的靈使骨枯乾",
    "reference": "箴言 17:22",
    "theme": "calm"
  },
  {
    "day_of_year": 196,
    "verse_text": "敬畏耶和華的，得著生命，他必恆久知足",
    "reference": "箴言 19:23",
    "theme": "peace"
  },
  {
    "day_of_year": 197,
    "verse_text": "堅心倚賴你的，你必保守他十分平安",
    "reference": "以賽亞書 26:3",
    "theme": "peace"
  },
  {
    "day_of_year": 198,
    "verse_text": "你們得救在乎歸回安息，你們得力在乎平靜安穩",
    "reference": "以賽亞書 30:15",
    "theme": "rest"
  },
  {
    "day_of_year": 199,
    "verse_text": "公義的果效必是平安，公義的效驗必是平穩",
    "reference": "以賽亞書 32:17",
    "theme": "peace"
  },
  {
    "day_of_year": 200,
    "verse_text": "你不要害怕，因為我與你同在",
    "reference": "以賽亞書 41:10",
    "theme": "calm"
  },
  {
    "day_of_year": 201,
    "verse_text": "因他受的鞭傷，我們得醫治",
    "reference": "以賽亞書 53:5",
    "theme": "peace"
  },
  {
    "day_of_year": 202,
    "verse_text": "我必親自和你同去，使你得安息",
    "reference": "出埃及記 33:14",
    "theme": "rest"
  },
  {
    "day_of_year": 203,
    "verse_text": "耶和華說，我知道我向你們所懷的意念，是賜平安的意念",
    "reference": "耶利米書 29:11",
    "theme": "peace"
  },
  {
    "day_of_year": 204,
    "verse_text": "疲乏的人我使他飽飫，愁煩的人我使他知足",
    "reference": "耶利米書 31:25",
    "theme": "rest"
  },
  {
    "day_of_year": 205,
    "verse_text": "滿了一把得享安靜，強如滿了兩把勞碌捕風",
    "reference": "傳道書 4:6",
    "theme": "rest"
  },
  {
    "day_of_year": 206,
    "verse_text": "事情的終局強如事情的起頭，存心忍耐的勝過居心驕傲的",
    "reference": "傳道書 7:8",
    "theme": "calm"
  },
  {
    "day_of_year": 207,
    "verse_text": "你因有指望就必穩固，也必四圍巡查，坦然安息",
    "reference": "約伯記 11:18",
    "theme": "rest"
  },
  {
    "day_of_year": 208,
    "verse_text": "你要認識神，就得平安，福氣也必臨到你",
    "reference": "約伯記 22:21",
    "theme": "peace"
  },
  {
    "day_of_year": 209,
    "verse_text": "不要為明天憂慮，明天自有明天的憂慮",
    "reference": "馬太福音 6:34",
    "theme": "calm"
  },
  {
    "day_of_year": 210,
    "verse_text": "凡勞苦擔重擔的人，可以到我這裡來，我就使你們得安息",
    "reference": "馬太福音 11:28",
    "theme": "rest"
  },
  {
    "day_of_year": 211,
    "verse_text": "我心裡柔和謙卑，你們當負我的軛，學我的樣式",
    "reference": "馬太福音 11:29",
    "theme": "rest"
  },
  {
    "day_of_year": 212,
    "verse_text": "住了吧，靜了吧，風就止住，大大地平靜了",
    "reference": "馬可福音 4:39",
    "theme": "calm"
  },
  {
    "day_of_year": 213,
    "verse_text": "馬大，馬大，你為許多的事思慮煩擾",
    "reference": "路加福音 10:41",
    "theme": "calm"
  },
  {
    "day_of_year": 214,
    "verse_text": "我留下平安給你們，我將我的平安賜給你們",
    "reference": "約翰福音 14:27",
    "theme": "peace"
  },
  {
    "day_of_year": 215,
    "verse_text": "在世上你們有苦難，但你們可以放心，我已經勝了世界",
    "reference": "約翰福音 16:33",
    "theme": "peace"
  },
  {
    "day_of_year": 216,
    "verse_text": "我們既因信稱義，就藉著我們的主耶穌基督得與神相和",
    "reference": "羅馬書 5:1",
    "theme": "peace"
  },
  {
    "day_of_year": 217,
    "verse_text": "體貼聖靈的乃是生命平安",
    "reference": "羅馬書 8:6",
    "theme": "peace"
  },
  {
    "day_of_year": 218,
    "verse_text": "但願使人有盼望的神，因信將諸般的喜樂平安充滿你們",
    "reference": "羅馬書 15:13",
    "theme": "peace"
  },
  {
    "day_of_year": 219,
    "verse_text": "願頌讚歸與我們的主耶穌基督的父神，就是發慈悲的父",
    "reference": "歌林多後書 1:3",
    "theme": "calm"
  },
  {
    "day_of_year": 220,
    "verse_text": "因他使我們和睦，將兩下合而為一",
    "reference": "以弗所書 2:14",
    "theme": "peace"
  },
  {
    "day_of_year": 221,
    "verse_text": "應當一無掛慮，只要凡事藉著禱告祈求，將所要的告訴神",
    "reference": "腓立比書 4:6",
    "theme": "calm"
  },
  {
    "day_of_year": 222,
    "verse_text": "神所賜出人意外的平安，必在基督耶穌裡保守你們的心",
    "reference": "腓立比書 4:7",
    "theme": "peace"
  },
  {
    "day_of_year": 223,
    "verse_text": "又要叫基督的平安在你們心裡作主",
    "reference": "歌羅西書 3:15",
    "theme": "peace"
  },
  {
    "day_of_year": 224,
    "verse_text": "願賜平安的主，隨時隨事親自給你們平安",
    "reference": "帖撒羅尼迦後書 3:16",
    "theme": "peace"
  },
  {
    "day_of_year": 225,
    "verse_text": "你們要將一切的憂慮卸給神，因為他顧念你們",
    "reference": "彼得前書 5:7",
    "theme": "rest"
  },
  {
    "day_of_year": 226,
    "verse_text": "這樣，必另有一安息日的安息，為神的子民存留",
    "reference": "希伯來書 4:9",
    "theme": "rest"
  },
  {
    "day_of_year": 227,
    "verse_text": "我總不撇下你，也不丟棄你",
    "reference": "希伯來書 13:5",
    "theme": "calm"
  },
  {
    "day_of_year": 228,
    "verse_text": "耶和華你的神是施行拯救，大有能力的主，他在你中間",
    "reference": "西番雅書 3:17",
    "theme": "peace"
  },
  {
    "day_of_year": 229,
    "verse_text": "凡投靠你的，願他們喜樂，時常歡呼",
    "reference": "詩篇 5:11",
    "theme": "peace"
  },
  {
    "day_of_year": 230,
    "verse_text": "耶和華又要給受欺壓的人作高臺，在患難的時候作高臺",
    "reference": "詩篇 9:9",
    "theme": "calm"
  },
  {
    "day_of_year": 231,
    "verse_text": "耶和華是我的巖石，我的山寨，我的救主",
    "reference": "詩篇 18:2",
    "theme": "calm"
  },
  {
    "day_of_year": 232,
    "verse_text": "要等候耶和華，當壯膽，堅固你的心",
    "reference": "詩篇 27:14",
    "theme": "rest"
  },
  {
    "day_of_year": 233,
    "verse_text": "凡仰望耶和華的人，你們都要壯膽，堅固你們的心",
    "reference": "詩篇 31:24",
    "theme": "calm"
  },
  {
    "day_of_year": 234,
    "verse_text": "你是我藏身之處，你必保佑我脫離苦難",
    "reference": "詩篇 32:7",
    "theme": "peace"
  },
  {
    "day_of_year": 235,
    "verse_text": "我們的心向來等候耶和華，他是我們的幫助",
    "reference": "詩篇 33:20",
    "theme": "rest"
  },
  {
    "day_of_year": 236,
    "verse_text": "我曾尋求耶和華，他就應允我，救我脫離了一切的恐懼",
    "reference": "詩篇 34:4",
    "theme": "calm"
  },
  {
    "day_of_year": 237,
    "verse_text": "耶和華靠近傷心的人，拯救靈性痛悔的人",
    "reference": "詩篇 34:18",
    "theme": "peace"
  },
  {
    "day_of_year": 238,
    "verse_text": "當將你的事交託耶和華，並倚靠他，他就必成全",
    "reference": "詩篇 37:5",
    "theme": "rest"
  },
  {
    "day_of_year": 239,
    "verse_text": "謙卑人必承受地土，以豐盛的平安為樂",
    "reference": "詩篇 37:11",
    "theme": "peace"
  },
  {
    "day_of_year": 240,
    "verse_text": "義人的腳步被耶和華立定，他的道路耶和華也喜愛",
    "reference": "詩篇 37:23",
    "theme": "calm"
  },
  {
    "day_of_year": 241,
    "verse_text": "我曾耐性等候耶和華，他垂聽我的呼求",
    "reference": "詩篇 40:1",
    "theme": "rest"
  },
  {
    "day_of_year": 242,
    "verse_text": "我的心哪，你為何憂悶，為何在我裡面煩躁",
    "reference": "詩篇 42:5",
    "theme": "calm"
  },
  {
    "day_of_year": 243,
    "verse_text": "所以地雖改變，山雖搖動到海心，我們也不害怕",
    "reference": "詩篇 46:2",
    "theme": "peace"
  },
  {
    "day_of_year": 244,
    "verse_text": "神啊，求你為我造清潔的心，使我裡面重新有正直的靈",
    "reference": "詩篇 51:10",
    "theme": "calm"
  },
  {
    "day_of_year": 245,
    "verse_text": "我懼怕的時候要倚靠你",
    "reference": "詩篇 56:3",
    "theme": "calm"
  },
  {
    "day_of_year": 246,
    "verse_text": "我要歌頌你的力量，早晨要高唱你的慈愛",
    "reference": "詩篇 59:16",
    "theme": "peace"
  },
  {
    "day_of_year": 247,
    "verse_text": "我心裡發昏的時候，我要從地極求告你",
    "reference": "詩篇 61:2",
    "theme": "rest"
  },
  {
    "day_of_year": 248,
    "verse_text": "你們眾民當時時倚靠他，在他面前傾心吐意",
    "reference": "詩篇 62:8",
    "theme": "rest"
  },
  {
    "day_of_year": 249,
    "verse_text": "天天背負我們重擔的主，就是拯救我們的神",
    "reference": "詩篇 68:19",
    "theme": "rest"
  },
  {
    "day_of_year": 250,
    "verse_text": "我卻要常常盼望，並要越發讚美你",
    "reference": "詩篇 71:14",
    "theme": "peace"
  },
  {
    "day_of_year": 251,
    "verse_text": "我的肉體和我的心腸衰殘，但神是我心裡的力量",
    "reference": "詩篇 73:26",
    "theme": "calm"
  },
  {
    "day_of_year": 252,
    "verse_text": "我要聽神耶和華所說的話，因為他必應許將平安賜給他",
    "reference": "詩篇 85:8",
    "theme": "peace"
  },
  {
    "day_of_year": 253,
    "verse_text": "主啊，你本為良善，樂意饒恕人",
    "reference": "詩篇 86:5",
    "theme": "calm"
  },
  {
    "day_of_year": 254,
    "verse_text": "求你使我們早早飽得你的慈愛，好叫我們一生一世歡呼",
    "reference": "詩篇 90:14",
    "theme": "peace"
  },
  {
    "day_of_year": 255,
    "verse_text": "他必用自己的翎毛遮蔽你，你要投靠在他的翅膀底下",
    "reference": "詩篇 91:4",
    "theme": "calm"
  },
  {
    "day_of_year": 256,
    "verse_text": "因他要為你吩咐他的使者，在你行的一切道路上保護你",
    "reference": "詩篇 91:11",
    "theme": "peace"
  },
  {
    "day_of_year": 257,
    "verse_text": "我正說我失了腳，耶和華啊，那時你的慈愛扶助我",
    "reference": "詩篇 94:18",
    "theme": "calm"
  },
  {
    "day_of_year": 258,
    "verse_text": "我的心哪，你要稱頌耶和華，不可忘記他的一切恩惠",
    "reference": "詩篇 103:2",
    "theme": "peace"
  },
  {
    "day_of_year": 259,
    "verse_text": "東離西有多遠，他叫我們的過犯離我們也有多遠",
    "reference": "詩篇 103:12",
    "theme": "peace"
  },
  {
    "day_of_year": 260,
    "verse_text": "他使狂風止息，波浪就平靜",
    "reference": "詩篇 107:29",
    "theme": "calm"
  },
  {
    "day_of_year": 261,
    "verse_text": "主啊，你救我的命免了死亡，救我的眼免了流淚",
    "reference": "詩篇 116:8",
    "theme": "peace"
  },
  {
    "day_of_year": 262,
    "verse_text": "有耶和華幫助我，我必不懼怕",
    "reference": "詩篇 118:6",
    "theme": "calm"
  },
  {
    "day_of_year": 263,
    "verse_text": "求你照著應許僕人的話，以慈愛安慰我",
    "reference": "詩篇 119:76",
    "theme": "peace"
  },
  {
    "day_of_year": 264,
    "verse_text": "保護你的是耶和華，耶和華在你右邊蔭庇你",
    "reference": "詩篇 121:5",
    "theme": "calm"
  },
  {
    "day_of_year": 265,
    "verse_text": "耶和華要保護你，免受一切的災害",
    "reference": "詩篇 121:7",
    "theme": "peace"
  },
  {
    "day_of_year": 266,
    "verse_text": "倚靠耶和華的人，好像錫安山，永不動搖",
    "reference": "詩篇 125:1",
    "theme": "rest"
  },
  {
    "day_of_year": 267,
    "verse_text": "我的心平穩安靜，好像斷過奶的孩子在他母親的懷中",
    "reference": "詩篇 131:2",
    "theme": "calm"
  },
  {
    "day_of_year": 268,
    "verse_text": "我呼求的日子，你就應允我，鼓勵我，使我心裡有能力",
    "reference": "詩篇 138:3",
    "theme": "peace"
  },
  {
    "day_of_year": 269,
    "verse_text": "神啊，求你鑒察我，知道我的心思",
    "reference": "詩篇 139:23",
    "theme": "calm"
  },
  {
    "day_of_year": 270,
    "verse_text": "耶和華啊，我曾向你哀求，我說，你是我的避難所",
    "reference": "詩篇 142:5",
    "theme": "rest"
  },
  {
    "day_of_year": 271,
    "verse_text": "求你使我清晨得聽你慈愛之言，因我倚靠你",
    "reference": "詩篇 143:8",
    "theme": "peace"
  },
  {
    "day_of_year": 272,
    "verse_text": "凡求告耶和華的，就是誠心求告他的，耶和華便與他們",
    "reference": "詩篇 145:18",
    "theme": "calm"
  },
  {
    "day_of_year": 273,
    "verse_text": "他醫好傷心的人，裹好他們的傷處",
    "reference": "詩篇 147:3",
    "theme": "peace"
  },
  {
    "day_of_year": 274,
    "verse_text": "惟有聽從我的，必安然居住，得享安靜",
    "reference": "箴言 1:33",
    "theme": "rest"
  },
  {
    "day_of_year": 275,
    "verse_text": "你要專心仰賴耶和華，不可倚靠自己的聰明",
    "reference": "箴言 3:5",
    "theme": "calm"
  },
  {
    "day_of_year": 276,
    "verse_text": "在你一切所行的事上都要認定他，他必指引你的路",
    "reference": "箴言 3:6",
    "theme": "calm"
  },
  {
    "day_of_year": 277,
    "verse_text": "耶和華所賜的福，使人富足，並不加上憂慮",
    "reference": "箴言 10:22",
    "theme": "peace"
  },
  {
    "day_of_year": 278,
    "verse_text": "人心憂慮屈而不伸，一句良言使心歡樂",
    "reference": "箴言 12:25",
    "theme": "calm"
  },
  {
    "day_of_year": 279,
    "verse_text": "敬畏耶和華的，大有倚靠，他的兒女也有避難所",
    "reference": "箴言 14:26",
    "theme": "calm"
  },
  {
    "day_of_year": 280,
    "verse_text": "你所作的，要交託耶和華，你所謀的，就必成立",
    "reference": "箴言 16:3",
    "theme": "rest"
  },
  {
    "day_of_year": 281,
    "verse_text": "耶和華的名是堅固臺，義人奔入便得安穩",
    "reference": "箴言 18:10",
    "theme": "calm"
  },
  {
    "day_of_year": 282,
    "verse_text": "敬畏耶和華的，得著生命，他必恆久知足",
    "reference": "箴言 19:23",
    "theme": "peace"
  },
  {
    "day_of_year": 283,
    "verse_text": "心中自是的，便是愚昧人，憑智慧行事的，必蒙拯救",
    "reference": "箴言 28:26",
    "theme": "calm"
  },
  {
    "day_of_year": 284,
    "verse_text": "他名稱為奇妙策士，全能的神，永在的父，和平的君",
    "reference": "以賽亞書 9:6",
    "theme": "peace"
  },
  {
    "day_of_year": 285,
    "verse_text": "看哪，神是我的拯救，我要倚靠他，並不懼怕",
    "reference": "以賽亞書 12:2",
    "theme": "calm"
  },
  {
    "day_of_year": 286,
    "verse_text": "因為當強暴人催逼人的時候，如同暴風直吹牆壁",
    "reference": "以賽亞書 25:4",
    "theme": "calm"
  },
  {
    "day_of_year": 287,
    "verse_text": "耶和華啊，求你施恩於我們，我們等候你",
    "reference": "以賽亞書 33:2",
    "theme": "rest"
  },
  {
    "day_of_year": 288,
    "verse_text": "但那等候耶和華的，必從新得力",
    "reference": "以賽亞書 40:31",
    "theme": "rest"
  },
  {
    "day_of_year": 289,
    "verse_text": "你從水中經過，我必與你同在",
    "reference": "以賽亞書 43:2",
    "theme": "calm"
  },
  {
    "day_of_year": 290,
    "verse_text": "我對你的慈愛永不離開，我平安的約也不遷移",
    "reference": "以賽亞書 54:10",
    "theme": "peace"
  },
  {
    "day_of_year": 291,
    "verse_text": "你們必歡歡喜喜而出來，平平安安蒙引導",
    "reference": "以賽亞書 55:12",
    "theme": "peace"
  },
  {
    "day_of_year": 292,
    "verse_text": "倚靠耶和華，以耶和華為可靠的，那人有福了",
    "reference": "耶利米書 17:7",
    "theme": "peace"
  },
  {
    "day_of_year": 293,
    "verse_text": "看哪，我要使這城得以痊愈安舒",
    "reference": "耶利米書 33:6",
    "theme": "peace"
  },
  {
    "day_of_year": 294,
    "verse_text": "凡事都有定期，天下萬務都有定時",
    "reference": "傳道書 3:1",
    "theme": "calm"
  },
  {
    "day_of_year": 295,
    "verse_text": "你不要心裡急躁惱怒，因為惱怒存在愚昧人的懷中",
    "reference": "傳道書 7:9",
    "theme": "calm"
  },
  {
    "day_of_year": 296,
    "verse_text": "你六次遭難，他必救你，就是七次，災禍也無法害你",
    "reference": "約伯記 5:19",
    "theme": "peace"
  },
  {
    "day_of_year": 297,
    "verse_text": "你就要以全能者為喜樂，向神仰起臉來",
    "reference": "約伯記 22:26",
    "theme": "peace"
  },
  {
    "day_of_year": 298,
    "verse_text": "使人和睦的人有福了，因為他們必稱為神的兒子",
    "reference": "馬太福音 5:9",
    "theme": "peace"
  },
  {
    "day_of_year": 299,
    "verse_text": "所以我告訴你們，不要為生命憂慮",
    "reference": "馬太福音 6:25",
    "theme": "calm"
  },
  {
    "day_of_year": 300,
    "verse_text": "你們放心，是我，不要怕",
    "reference": "馬太福音 14:27",
    "theme": "calm"
  },
  {
    "day_of_year": 301,
    "verse_text": "你們來同我暗暗地到曠野地方去歇一歇",
    "reference": "馬可福音 6:31",
    "theme": "rest"
  },
  {
    "day_of_year": 302,
    "verse_text": "在至高之處榮耀歸與神，在地上平安歸與他所喜悅的人",
    "reference": "路加福音 2:14",
    "theme": "peace"
  },
  {
    "day_of_year": 303,
    "verse_text": "不要怕，只要信",
    "reference": "路加福音 8:50",
    "theme": "calm"
  },
  {
    "day_of_year": 304,
    "verse_text": "你們心裡不要憂愁，你們信神，也當信我",
    "reference": "約翰福音 14:1",
    "theme": "calm"
  },
  {
    "day_of_year": 305,
    "verse_text": "我不撇下你們為孤兒，我必到你們這裡來",
    "reference": "約翰福音 14:18",
    "theme": "peace"
  },
  {
    "day_of_year": 306,
    "verse_text": "萬事都互相效力，叫愛神的人得益處",
    "reference": "羅馬書 8:28",
    "theme": "peace"
  },
  {
    "day_of_year": 307,
    "verse_text": "因為我深信無論是死，是生，都不能叫我們與神的愛隔絕",
    "reference": "羅馬書 8:38",
    "theme": "peace"
  },
  {
    "day_of_year": 308,
    "verse_text": "若是能行，總要盡力與眾人和睦",
    "reference": "羅馬書 12:18",
    "theme": "peace"
  },
  {
    "day_of_year": 309,
    "verse_text": "所以我們不喪膽，外體雖然毀壞，內心卻一天新似一天",
    "reference": "歌林多後書 4:16",
    "theme": "calm"
  },
  {
    "day_of_year": 310,
    "verse_text": "又用平安的福音當作預備走路的鞋穿在腳上",
    "reference": "以弗所書 6:15",
    "theme": "peace"
  },
  {
    "day_of_year": 311,
    "verse_text": "弟兄們，我還有未盡的話，凡是真實的，可敬的，公義",
    "reference": "腓立比書 4:8",
    "theme": "calm"
  },
  {
    "day_of_year": 312,
    "verse_text": "你們在我身上所學習的，所領受的，所聽見的，所看見",
    "reference": "腓立比書 4:9",
    "theme": "peace"
  },
  {
    "day_of_year": 313,
    "verse_text": "既然藉著他在十字架上所流的血成就了和平",
    "reference": "歌羅西書 1:20",
    "theme": "peace"
  },
  {
    "day_of_year": 314,
    "verse_text": "也要離惡行善，尋求和睦，一心追趕",
    "reference": "彼得前書 3:11",
    "theme": "peace"
  },
  {
    "day_of_year": 315,
    "verse_text": "所以我們只管坦然無懼地來到施恩的寶座前",
    "reference": "希伯來書 4:16",
    "theme": "calm"
  },
  {
    "day_of_year": 316,
    "verse_text": "你們要追求與眾人和睦",
    "reference": "希伯來書 12:14",
    "theme": "peace"
  },
  {
    "day_of_year": 317,
    "verse_text": "我躺下睡覺，我醒著，耶和華都保佑我",
    "reference": "詩篇 3:5",
    "theme": "sleep"
  },
  {
    "day_of_year": 318,
    "verse_text": "我必安然躺下睡覺，耶和華使我安然居住",
    "reference": "詩篇 4:8",
    "theme": "sleep"
  },
  {
    "day_of_year": 319,
    "verse_text": "你們應當畏懼，不可犯罪",
    "reference": "詩篇 4:4",
    "theme": "calm"
  },
  {
    "day_of_year": 320,
    "verse_text": "我的心歡喜，我的靈快樂，肉身安然居住",
    "reference": "詩篇 16:9",
    "theme": "peace"
  },
  {
    "day_of_year": 321,
    "verse_text": "耶和華是我的牧者，我必不致缺乏",
    "reference": "詩篇 23:1",
    "theme": "peace"
  },
  {
    "day_of_year": 322,
    "verse_text": "他使我躺臥在青草地上，領我在可安歇的水邊",
    "reference": "詩篇 23:2",
    "theme": "rest"
  },
  {
    "day_of_year": 323,
    "verse_text": "他使我的靈魂甦醒，為自己的名引導我走義路",
    "reference": "詩篇 23:3",
    "theme": "calm"
  },
  {
    "day_of_year": 324,
    "verse_text": "我雖然行過死蔭的幽谷，也不怕遭害",
    "reference": "詩篇 23:4",
    "theme": "peace"
  },
  {
    "day_of_year": 325,
    "verse_text": "在我敵人面前，你為我擺設筵席",
    "reference": "詩篇 23:5",
    "theme": "calm"
  },
  {
    "day_of_year": 326,
    "verse_text": "我一生一世必有恩惠慈愛隨著我",
    "reference": "詩篇 23:6",
    "theme": "peace"
  },
  {
    "day_of_year": 327,
    "verse_text": "耶和華是我的亮光，是我的拯救",
    "reference": "詩篇 27:1",
    "theme": "calm"
  },
  {
    "day_of_year": 328,
    "verse_text": "耶和華必賜平安的福給他的百姓",
    "reference": "詩篇 29:11",
    "theme": "peace"
  },
  {
    "day_of_year": 329,
    "verse_text": "你們要嘗嘗主恩的滋味，便知道他是美善",
    "reference": "詩篇 34:8",
    "theme": "calm"
  },
  {
    "day_of_year": 330,
    "verse_text": "要離惡行善，尋求和睦，一心追趕",
    "reference": "詩篇 34:14",
    "theme": "peace"
  },
  {
    "day_of_year": 331,
    "verse_text": "又要以耶和華為樂，他就將你心裡所求的賜給你",
    "reference": "詩篇 37:4",
    "theme": "peace"
  },
  {
    "day_of_year": 332,
    "verse_text": "你當默然倚靠耶和華，耐性等候他",
    "reference": "詩篇 37:7",
    "theme": "rest"
  },
  {
    "day_of_year": 333,
    "verse_text": "神是我們的避難所，是我們的力量",
    "reference": "詩篇 46:1",
    "theme": "calm"
  },
  {
    "day_of_year": 334,
    "verse_text": "你們要休息，要知道我是神",
    "reference": "詩篇 46:10",
    "theme": "rest"
  },
  {
    "day_of_year": 335,
    "verse_text": "你要把你的重擔卸給耶和華，他必撫養你",
    "reference": "詩篇 55:22",
    "theme": "rest"
  },
  {
    "day_of_year": 336,
    "verse_text": "我的心默默無聲，專等候神",
    "reference": "詩篇 62:1",
    "theme": "rest"
  },
  {
    "day_of_year": 337,
    "verse_text": "我的心哪，你當默然無聲，專等候神",
    "reference": "詩篇 62:5",
    "theme": "calm"
  },
  {
    "day_of_year": 338,
    "verse_text": "我在床上記念你，在夜更的時候思想你",
    "reference": "詩篇 63:5",
    "theme": "sleep"
  },
  {
    "day_of_year": 339,
    "verse_text": "我在床上記念你，我的心就像飽足了骨髓肥油",
    "reference": "詩篇 63:6",
    "theme": "peace"
  },
  {
    "day_of_year": 340,
    "verse_text": "住在至高者隱密處的，必住在全能者的蔭下",
    "reference": "詩篇 91:1",
    "theme": "calm"
  },
  {
    "day_of_year": 341,
    "verse_text": "我要論到耶和華說，他是我的避難所",
    "reference": "詩篇 91:2",
    "theme": "peace"
  },
  {
    "day_of_year": 342,
    "verse_text": "我的心哪，你要仍歸安樂，因為耶和華用厚恩待你",
    "reference": "詩篇 116:7",
    "theme": "peace"
  },
  {
    "day_of_year": 343,
    "verse_text": "保護以色列的也不打盹也不睡覺",
    "reference": "詩篇 121:3",
    "theme": "sleep"
  },
  {
    "day_of_year": 344,
    "verse_text": "保護以色列的，也不打盹也不睡覺",
    "reference": "詩篇 121:4",
    "theme": "calm"
  },
  {
    "day_of_year": 345,
    "verse_text": "惟有耶和華所親愛的，必叫他安然睡覺",
    "reference": "詩篇 127:2",
    "theme": "sleep"
  },
  {
    "day_of_year": 346,
    "verse_text": "我心裡多憂多疑，你安慰我，就使我歡樂",
    "reference": "詩篇 94:19",
    "theme": "peace"
  },
  {
    "day_of_year": 347,
    "verse_text": "愛你律法的人有大平安，什麼都不能使他們絆腳",
    "reference": "詩篇 119:165",
    "theme": "peace"
  },
  {
    "day_of_year": 348,
    "verse_text": "我雖行在患難中，你必將我救活",
    "reference": "詩篇 138:7",
    "theme": "calm"
  },
  {
    "day_of_year": 349,
    "verse_text": "我睡醒的時候，仍和你同在",
    "reference": "詩篇 139:18",
    "theme": "sleep"
  },
  {
    "day_of_year": 350,
    "verse_text": "你躺下必不懼怕，你躺臥睡得香甜",
    "reference": "箴言 3:24",
    "theme": "sleep"
  },
  {
    "day_of_year": 351,
    "verse_text": "心中安靜是肉體的生命",
    "reference": "箴言 14:30",
    "theme": "calm"
  },
  {
    "day_of_year": 352,
    "verse_text": "人所行的若蒙耶和華喜悅，耶和華也使他的仇敵與他和好",
    "reference": "箴言 16:7",
    "theme": "peace"
  },
  {
    "day_of_year": 353,
    "verse_text": "喜樂的心乃是良藥，憂傷的靈使骨枯乾",
    "reference": "箴言 17:22",
    "theme": "calm"
  },
  {
    "day_of_year": 354,
    "verse_text": "敬畏耶和華的，得著生命，他必恆久知足",
    "reference": "箴言 19:23",
    "theme": "peace"
  },
  {
    "day_of_year": 355,
    "verse_text": "堅心倚賴你的，你必保守他十分平安",
    "reference": "以賽亞書 26:3",
    "theme": "peace"
  },
  {
    "day_of_year": 356,
    "verse_text": "你們得救在乎歸回安息，你們得力在乎平靜安穩",
    "reference": "以賽亞書 30:15",
    "theme": "rest"
  },
  {
    "day_of_year": 357,
    "verse_text": "公義的果效必是平安，公義的效驗必是平穩",
    "reference": "以賽亞書 32:17",
    "theme": "peace"
  },
  {
    "day_of_year": 358,
    "verse_text": "你不要害怕，因為我與你同在",
    "reference": "以賽亞書 41:10",
    "theme": "calm"
  },
  {
    "day_of_year": 359,
    "verse_text": "因他受的鞭傷，我們得醫治",
    "reference": "以賽亞書 53:5",
    "theme": "peace"
  },
  {
    "day_of_year": 360,
    "verse_text": "我必親自和你同去，使你得安息",
    "reference": "出埃及記 33:14",
    "theme": "rest"
  },
  {
    "day_of_year": 361,
    "verse_text": "耶和華說，我知道我向你們所懷的意念，是賜平安的意念",
    "reference": "耶利米書 29:11",
    "theme": "peace"
  },
  {
    "day_of_year": 362,
    "verse_text": "疲乏的人我使他飽飫，愁煩的人我使他知足",
    "reference": "耶利米書 31:25",
    "theme": "rest"
  },
  {
    "day_of_year": 363,
    "verse_text": "滿了一把得享安靜，強如滿了兩把勞碌捕風",
    "reference": "傳道書 4:6",
    "theme": "rest"
  },
  {
    "day_of_year": 364,
    "verse_text": "事情的終局強如事情的起頭，存心忍耐的勝過居心驕傲的",
    "reference": "傳道書 7:8",
    "theme": "calm"
  },
  {
    "day_of_year": 365,
    "verse_text": "你因有指望就必穩固，也必四圍巡查，坦然安息",
    "reference": "約伯記 11:18",
    "theme": "rest"
  }
]