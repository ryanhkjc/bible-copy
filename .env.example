# 聖經抄寫平靜網站 - 環境變數範例
# 複製為 .env 並填入實際值

# 家長 Dashboard 密碼（必填）
PARENT_PASSWORD=your-secure-password

# Session 加密金鑰（建議隨機字串）
SESSION_SECRET=change-me-to-random-string

# 伺服器埠號（選填，預設 3000）
PORT=3000

# 測試用日期選擇器（非生產環境）
# NODE_ENV !== production 時自動啟用；或設為 true 強制啟用
# 兒童主頁會顯示日期選擇器，可模擬不同日期測試經文、心情、日誌
ENABLE_TEST_DATE_PICKER=true
