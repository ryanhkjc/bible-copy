# 聖經抄寫平靜網站 - 環境變數範例
# 複製為 .env 並填入實際值

# 家長 Dashboard 密碼（必填）
PARENT_PASSWORD=your-secure-password

# Session 加密金鑰（建議隨機字串）
SESSION_SECRET=change-me-to-random-string

# 伺服器埠號（選填，預設 3000）
PORT=3000

# 測試用日期選擇器（非生產環境）
# NODE_ENV !== production 時自動啟用；或設為 true 強制啟用
# 兒童主頁會顯示日期選擇器，可模擬不同日期測試經文、心情、日誌
ENABLE_TEST_DATE_PICKER=true

# --- Cloudflare Workers AI（選填；未設定則聊天按鈕會顯示提示）---
# 儀表板：Workers AI → Use REST API → Account ID、Create Workers AI API Token
CF_ACCOUNT_ID=
CF_API_TOKEN=
# 模型名稱須與官方目錄一致，例如 @cf/meta/llama-3.2-3b-instruct
AI_MODEL=@cf/meta/llama-3.2-3b-instruct
# 單次回覆上限（約束用量與 Neurons）
AI_MAX_TOKENS=512
# 每日「小朋友發話」則數上限（全模式合計）
AI_MAX_USER_TURNS_PER_DAY=25
# 帶入模型之過往對話摘要字元上限（由 Markdown 日誌尾端與昨日截斷組成）
AI_CONTEXT_MAX_CHARS=3500
# 單則使用者訊息最大字元數
AI_MAX_USER_MESSAGE_CHARS=2000
