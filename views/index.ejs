<!DOCTYPE html>
<html lang="zh-Hant">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>今日的平靜句子 - 聖經抄寫</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="child-page" data-verse-id="<%= verse ? verse.id : '' %>" data-today="<%= today %>">
  <header class="header">
    <a href="/parent/login" class="parent-link" title="家長登入">🔐</a>
    <div class="mascot mascot-float">
      <svg class="mascot-svg" viewBox="0 0 80 80" aria-hidden="true">
        <circle cx="40" cy="40" r="36" fill="#ffd93d" stroke="#f0c020" stroke-width="2" />
        <circle cx="32" cy="36" r="4" fill="#5c4033" />
        <circle cx="48" cy="36" r="4" fill="#5c4033" />
        <path d="M 28 48 Q 40 56 52 48" stroke="#5c4033" stroke-width="2" fill="none" stroke-linecap="round" />
        <path d="M 20 20 L 24 16 L 28 20 L 24 24 Z" fill="#fff9e6" />
        <path d="M 52 14 L 56 10 L 60 14 L 56 18 Z" fill="#fff9e6" />
      </svg>
    </div>
    <h1 class="welcome">今日的平靜句子</h1>
  </header>

  <main class="main">
    <% if (typeof error !=='undefined' && error) { %>
      <p class="error-msg">
        <%= error %>
      </p>
      <% } else if (verse) { %>
        <section class="verse-section animate-in">
          <p class="verse-text">
            <%= verse.verse_text %>
          </p>
          <p class="verse-ref">
            <%= verse.reference %>
          </p>
          <!--<p class="copy-hint">抄在筆記本上吧！</p>-->
        </section>

        <section class="record-section animate-in animate-delay-1">
          <h2>今日心情</h2>
          <p class="today-date">
            <%= today %>
          </p>

          <div class="mood-select">
            <span class="mood-label">今日心情（必選）：</span>
            <div class="mood-buttons">
              <button type="button" class="mood-btn" data-mood="😊" title="開心">😊</button>
              <button type="button" class="mood-btn" data-mood="🙂" title="不錯">🙂</button>
              <button type="button" class="mood-btn" data-mood="😐" title="普通">😐</button>
              <button type="button" class="mood-btn" data-mood="😔" title="難過">😔</button>
              <button type="button" class="mood-btn" data-mood="😴" title="想睡">😴</button>
            </div>
          </div>

          <div class="journal-input">
            <label for="journal">今日日誌（選填）：</label>
            <textarea id="journal" rows="3"
              placeholder="寫下今天發生的事..."><%= record && record.journal ? record.journal : '' %></textarea>
          </div>

          <button type="button" class="save-btn" id="saveBtn">儲存今日記錄</button>
          <p class="save-status" id="saveStatus"></p>
        </section>

        <section class="rewards-section animate-in animate-delay-2">
          <h2>我的獎勵</h2>
          <div class="streak-display">
            <span class="streak-label">連續天數：</span>
            <span class="streak-value" id="streakValue">-</span>
          </div>
          <div class="achievements" id="achievements">
            <span class="badge" data-achievement="streak_3" title="連續 3 天">⭐</span>
            <span class="badge" data-achievement="streak_7" title="連續 7 天">🏅</span>
            <span class="badge" data-achievement="streak_30" title="連續 30 天">🏆</span>
            <span class="badge" data-achievement="total_50" title="累積 50 句">🎖️</span>
            <span class="badge" data-achievement="total_100" title="累積 100 句">🌟</span>
          </div>
        </section>
        <% } else { %>
          <p class="error-msg">今日經文載入失敗，請稍後再試。</p>
          <% } %>
  </main>

  <script src="/js/child.js"></script>
</body>

</html>